<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginLeft="100dp"
    android:layout_marginTop="50dp"
    android:textAlignment="center"
    tools:context=".MainActivity">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Salario por hora:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <EditText
            android:id="@+id/etSalario"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:hint="bote texsto"
            android:inputType="text"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Horas trabalhadas:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <EditText
            android:id="@+id/etHorasTrab"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:hint="bote tesxto!"
            android:inputType="text"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Anos de trabalho:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <EditText
            android:id="@+id/etAnosTrab"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:hint="bote tesxto!"
            android:inputType="text"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="É sobrinho do patrão?:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <EditText
            android:id="@+id/etESobri"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:hint="bote tesxto!"
            android:inputType="text"
        />
        <Button
            android:id="@+id/btnCalc"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="Calcular"

        />
        <TextView
            android:id="@+id/tvResul"
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:text="Resultado:"/>
</LinearLayout>